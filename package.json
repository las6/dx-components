{
  "name": "dx-components",
  "version": "1.2.0",
  "description": "Copy-paste-ready DX components for Vite + TanStack",
  "type": "module",
  "exports": {
    "./components/ErrorComponent": "./components/ErrorComponent.tsx",
    "./components/NotFoundComponent": "./components/NotFoundComponent.tsx",
    "./components/PendingComponent": "./components/PendingComponent.tsx",
    "./components/ErrorPage": "./components/ErrorPage.tsx"
  },
  "files": [
    "components/"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "scripts": {
    "dev": "vite --config dev/vite.config.ts",
    "docs:dev": "astro dev",
    "docs:build": "astro build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync-version": "node scripts/sync-version.mjs",
    "version:check": "node scripts/sync-version.mjs --check",
    "preversion": "node scripts/sync-version.mjs"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/las6/dx-components"
  },
  "devDependencies": {
    "@astrojs/react": "^5.0.7",
    "@astrojs/starlight": "^0.39.3",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.4",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
