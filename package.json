{
  "name": "dx-components",
  "version": "1.2.0",
  "description": "Copy-paste-ready DX components for Vite + TanStack",
  "type": "module",
  "exports": {
    "./components/ErrorComponent": "./components/ErrorComponent.tsx",
    "./components/NotFoundComponent": "./components/NotFoundComponent.tsx",
    "./components/PendingComponent": "./components/PendingComponent.tsx",
    "./components/ErrorPage": "./components/ErrorPage.tsx"
  },
  "files": [
    "components/"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "scripts": {
    "dev": "npm run --prefix dev dev",
    "docs:dev": "astro dev",
    "docs:build": "astro build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync-version": "node scripts/sync-version.mjs",
    "version:check": "node scripts/sync-version.mjs --check",
    "preversion": "node scripts/sync-version.mjs"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/las6/dx-components"
  },
  "devDependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/starlight": "^0.41.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "centry-client": "^1.2.1"
  }
}
